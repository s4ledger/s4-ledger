# ─── S4 Ledger Demo Application ───────────────────────────
# Copy this file to .env and fill in your values.
# All VITE_ prefixed vars are exposed to the browser at build time.

# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Sentry (optional — error tracking)
VITE_SENTRY_DSN=

# ─── NSERC IDE / PMS 300 Connection ──────────────────────
# These enable real NSERC IDE sync (instead of simulation mode).
# Non-secret values — safe for VITE_ prefix (exposed to browser).
VITE_AZURE_TENANT_ID=
VITE_AZURE_CLIENT_ID=
VITE_PMS300_SITE_ID=
VITE_PMS300_DRL_LIST_ID=
VITE_PMS300_DOC_DRIVE_ID=

# App mode: 'demo' (default, uses demoDefaults) or 'production' (loads s4-config.json)
VITE_APP_MODE=demo
