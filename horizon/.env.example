# HORIZON — environment variables (example)
# Copy to `.env` and fill in real values. Never commit `.env`.

# ── Deployment mode ────────────────────────────────────────────────
# one of: stub | dev | prod
HORIZON_MODE=stub

# ── Server ────────────────────────────────────────────────────────
HORIZON_HOST=0.0.0.0
HORIZON_PORT=8088
HORIZON_CORS_ORIGINS=http://localhost:8088,https://s4ledger.com

# ── Persistence ───────────────────────────────────────────────────
# SQLite path (default for stub/dev). For prod, point at managed Postgres.
HORIZON_DB_URL=sqlite:///./horizon.db

# ── LLM providers (stub mode ignores these) ───────────────────────
# Uncomment + populate when ready to flip HORIZON_MODE to dev/prod.
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# ── Auth (prod only) ──────────────────────────────────────────────
# Header `X-Horizon-Token` must equal this value when MODE=prod.
HORIZON_API_TOKEN=

# ── Knowledge base ────────────────────────────────────────────────
HORIZON_KB_PATH=knowledge_base

# ── Audit & redaction ─────────────────────────────────────────────
HORIZON_AUDIT_ENABLED=true
HORIZON_REDACT_PII=true
