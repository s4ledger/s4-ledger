# S4ight backend environment variables (copy to .env and adjust).
# Note: this app reads env vars directly; no python-dotenv required.
# To load a .env, prefix your run command: `set -a; source .env; set +a; python main.py`

# --- LLM provider ---
# "openai" (hosted, production / Vercel) or "ollama" (local)
S4IGHT_LLM_PROVIDER=openai

# --- OpenAI ---
# OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_S=60
OPENAI_TEMPERATURE=0.2
# OPENAI_BASE_URL=https://api.openai.com/v1   # override for Azure / OpenRouter

# --- Ollama (local) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1
OLLAMA_TIMEOUT_S=120
OLLAMA_TEMPERATURE=0.2

# Require LLM (true) or allow retrieval-only fallback (false).
S4IGHT_REQUIRE_LLM=false

# --- API ---
S4IGHT_API_HOST=0.0.0.0
S4IGHT_API_PORT=8000

# Comma-separated allowed CORS origins for the browser frontend.
S4IGHT_CORS_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:8000,http://127.0.0.1:8000,https://s4ledger.com,https://www.s4ledger.com,null

# --- Safety / limits ---
S4IGHT_MAX_MESSAGE_CHARS=8000
S4IGHT_MAX_CONTEXT_CHARS=8000
S4IGHT_MAX_HISTORY_TURNS=6

# --- Paths (override if your folder layout differs) ---
# S4IGHT_KNOWLEDGE_DIR=/abs/path/to/s4ight_knowledge
# S4IGHT_FRONTEND_DIR=/abs/path/to/frontend
